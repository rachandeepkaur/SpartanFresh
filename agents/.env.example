# Required for the translation agent's Claude fallback (unrecognized
# partner formats) and for Claude-phrased briefs. Without this, both fall
# back to deterministic/heuristic logic so the pipeline still runs.
ANTHROPIC_API_KEY=

# Optional. Leave blank to persist to a local JSON file
# (agents/data/local_store.json) instead -- no code changes needed either
# way, storage.py picks whichever is configured.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
